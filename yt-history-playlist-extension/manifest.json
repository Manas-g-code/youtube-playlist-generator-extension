{
  "manifest_version": 3,
  "name": "YT History Playlist Generator",
  "version": "1.0",
  "description": "Create playlist from Punjabi/Haryanvi songs in YouTube history",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/feed/history*"],
      "js": ["content.js"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  }
}